---
import type { MarkdownHeading } from "astro";
import PageLayout from "./PageLayout.astro";

interface Props {
    title?: string;
    seoTitle?: string;
    seoDescription?: string;
    headings?: MarkdownHeading[];
}

const wikiMaxNavDepth = 3;

const { frontmatter, headings = [] } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth <= wikiMaxNavDepth);
---

<PageLayout frontmatter={frontmatter}>
    <div class="flex flex-col sm:flex-row">
        <aside
            class="flex-shrink-0 sm:w-1/5 sm:sticky sm:top-16 h-full sm:pr-8 sm:pt-10 sm:pb-24 max-h-dvh overflow-x-scroll"
        >
            <h1
                class="sm:mt-0 max-sm:text-center max-sm:inline-block max-sm:w-full"
            >
                {frontmatter.title}
            </h1>
            <ul class="list-none max-sm:hidden text-2xl">
                {
                    filteredHeadings.map((heading) => (
                        <li
                            class:list={[
                                "leading-tight py-1",
                                { "mb-3": heading.depth === 1 },
                                { "pl-4 text-xl": heading.depth === 2 },
                                { "pl-8 text-base": heading.depth === 3 },
                            ]}
                        >
                            <a class="inline-block" href={`#${heading.slug}`}>
                                {heading.text}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>

        <div
            class="wiki-content sm:-mt-16 sm:-mb-4 sm:pt-28 sm:pb-4 sm:border-l sm:border-border sm:pl-8"
        >
            <slot />
        </div>
    </div>
</PageLayout>

<style>
    :global(.wiki-content > *:first-child) {
        margin-top: 0 !important;
    }

    .wiki-content :global(h2) {
        @apply border-b border-border pb-2 mt-20;
    }

    .wiki-content :global(h2:hover a),
    .wiki-content :global(h3:hover a),
    .wiki-content :global(h4:hover a),
    .wiki-content :global(h5:hover a),
    .wiki-content :global(h6:hover a) {
        @apply block;
    }
</style>

<script>
    // Enable smooth scroll after page load to avoid jarring initial scroll behaviour
    setTimeout(() => {
        document.documentElement.style.scrollBehavior = "smooth";
    }, 100);
</script>

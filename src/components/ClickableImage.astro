---
import { Image } from "astro:assets";

export interface Props {
    src: ImageMetadata;
    alt: string;
}

const { src, alt } = Astro.props;
---

<figure
    class="group overflow-hidden border border-border bg-secondary-bg shadow-sm transition-transform duration-150 ease-in-out hover:-translate-y-0.5 hover:shadow-md"
>
    <a
        href={src.src}
        target="_blank"
        rel="noopener"
        aria-label={`Bild in neuem Tab öffnen`}
        title="Bild in neuem Tab öffnen"
        class="block"
    >
        <Image
            src={src}
            alt={alt}
            loading="lazy"
            class="w-full object-cover transition-transform duration-50 ease-in-out group-hover:scale-105"
        />
    </a>
</figure>
